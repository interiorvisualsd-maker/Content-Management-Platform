# ============================================
# Supabase (get these from console.supabase.com)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
SUPABASE_STORAGE_BUCKET=audio-files

# ============================================
# Groq (get this from console.groq.com) — covers BOTH transcription & LLM
# ============================================
GROQ_API_KEY=gsk_your_groq_api_key_here

# ============================================
# Admin auth (you choose these — any values you'll remember)
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# ============================================
# App URL (set to your Vercel URL in production)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
